# Environment Configuration for Option 1 (Raw FDW)
NODE_ENV=development
HOST=0.0.0.0
PORT=3331
LOG_LEVEL=info
APP_KEY=demo-benchmark-app-key-12345678901234567890

# Database Connection (connects to EU database as primary)
DB_CONNECTION=pg
DB_HOST=localhost
DB_PORT=5452
DB_USER=app_user
DB_PASSWORD=app123
DB_DATABASE=institutions_db

# Region Configuration
DB_REGION=eu
DB_IS_MASTER=false

# Option Type: raw_fdw (Option 1)
OPTION_TYPE=raw_fdw

# Multi-region Database Hosts
US_DB_HOST=localhost
US_DB_PORT=5450
CHINA_DB_HOST=localhost
CHINA_DB_PORT=5451
EU_DB_HOST=localhost
EU_DB_PORT=5452
